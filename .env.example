# Database Configuration
DATABASE_URL=postgres://kb:kb@localhost:5432/kb_freshness

# Confluence Cloud (Required for article sync)
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your-api-token-here
CONFLUENCE_SPACE_KEY=KB

# Jira Cloud (Optional - for ticket correlation)
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-api-token-here

# Ollama (Optional - for LLM suggestions)
# OLLAMA_URL=http://localhost:11434

# Logging
RUST_LOG=info,kb_freshness_detector=debug
